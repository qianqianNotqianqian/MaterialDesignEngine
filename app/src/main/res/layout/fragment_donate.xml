<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:context="mapleleaf.materialdesign.engine.ui.fragments.FragmentOverViewDonate">

    <include
        layout="@layout/this_application_toolbar"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/pay_paypal"
                style="@style/ListCardItemClickable">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_paypal"
                    android:textColor="?android:colorAccent" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pay_alipay"
                style="@style/ListCardItemClickable">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_aliPay"
                    android:textColor="?android:colorAccent" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pay_wechat"
                style="@style/ListCardItemClickable">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_wechat"
                    android:textColor="?android:colorAccent" />
            </LinearLayout>

            <LinearLayout style="@style/ListCardItemClickable">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_free_donation_alipay_red_packet"
                    android:textColor="?android:colorAccent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/pay_alipay_code"
                    style="@style/textSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/support_red_packet_num" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/pay_alipay_command"
                    style="@style/textSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/support_red_packet_code" />
            </LinearLayout>

            <LinearLayout style="@style/ListCardItemClickableLast">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmall"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/support_help_title"
                    android:textColor="?android:colorAccent" />

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/support_help_title2" />

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/support_help_title3" />
            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</LinearLayout>
