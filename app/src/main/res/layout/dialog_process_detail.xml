<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/materialCardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="@color/background"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ProcessIcon"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_gravity="center"
                android:src="@drawable/process_linux" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/ProcessName"
                style="@style/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textIsSelectable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_pid" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessPID"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_user" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessUSER"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_cpu_avg" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessCPU"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_res" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessMEM"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_swap" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessSWAP"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_app_name" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessFriendlyName"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_command" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessCommand"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_command_line" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessCmdline"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_status" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessState"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_cpuset" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessCpuSet"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_cgroup" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessCGroup"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:text="@string/process_oom_adj" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessOOMADJ"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />

                <com.google.android.material.textview.MaterialTextView
                    style="@style/textSmallTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="12dp"
                    android:text="@string/process_oom_score_adj" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ProcessOOMScoreAdj"
                    style="@style/textSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ProcessStopApp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/item_app_bg"
                    android:paddingHorizontal="6dp"
                    android:text="@string/process_kill_app"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ProcessKill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/item_app_bg"
                    android:padding="0dp"
                    android:text="@string/process_stop" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
