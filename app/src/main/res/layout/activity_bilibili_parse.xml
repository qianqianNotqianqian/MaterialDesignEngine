<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.activities.ActivityBilibiliParse">

    <include
        android:id="@+id/include"
        layout="@layout/this_application_toolbar" />

    <LinearLayout
        android:id="@+id/linearLayout4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/include">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/background"
            app:cardCornerRadius="12dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/videoCoverUrlImageView"
                android:layout_width="match_parent"
                android:layout_height="225dp"
                android:scaleType="centerCrop" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingTop="3dp"
                android:paddingEnd="12dp"
                android:paddingBottom="3dp"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:maxLines="1"
                    android:textColor="@color/text_color"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="3dp"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/stat_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_bofang"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:textColor="@color/text_color"
                    android:textSize="12sp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/stat_danmu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:drawableStart="@drawable/ic_danmu"
                    android:drawablePadding="4dp"
                    android:textColor="@color/text_color"
                    android:textSize="12sp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/text_color"
                    android:textSize="12sp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:drawableStart="@drawable/ic_views"
                    android:drawablePadding="4dp"
                    android:textColor="@color/text_color"
                    android:textSize="12sp"
                    tools:ignore="SmallSp" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="人在看"
                    android:textColor="@color/text_color"
                    android:textSize="12sp"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="7.0dip">

                <LinearLayout
                    android:id="@+id/frame_recommend"
                    android:layout_width="0.0dip"
                    android:layout_height="51.0dip"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/frame_dislike"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="30.0dip"
                        android:layout_height="30.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/recommend_icon"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_like" />
                    </FrameLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/stat_dianzan"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frame_dislike"
                    android:layout_width="0.0dip"
                    android:layout_height="51.0dip"
                    android:foreground="?selectableItemBackgroundBorderless"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/frame_coin"
                    app:layout_constraintStart_toEndOf="@+id/frame_recommend"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="30.0dip"
                        android:layout_height="30.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/dislike_icon"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_dislike" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/dislike_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/action_dislike"
                        android:textColor="@color/text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frame_coin"
                    android:layout_width="0.0dip"
                    android:layout_height="51.0dip"
                    android:foreground="?selectableItemBackgroundBorderless"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/frame_fav"
                    app:layout_constraintStart_toEndOf="@+id/frame_dislike"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="30.0dip"
                        android:layout_height="30.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/coin_icon"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_coin"
                            android:tint="@color/text_color" />

                    </FrameLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/stat_toubi"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frame_fav"
                    android:layout_width="0.0dip"
                    android:layout_height="51.0dip"
                    android:foreground="?selectableItemBackgroundBorderless"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/frame_share"
                    app:layout_constraintStart_toEndOf="@+id/frame_coin"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="30.0dip"
                        android:layout_height="30.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/favorite_icon"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_favorite" />

                    </FrameLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/stat_shoucang"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frame_share"
                    android:layout_width="0.0dip"
                    android:layout_height="51.0dip"
                    android:foreground="?selectableItemBackgroundBorderless"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toEndOf="@+id/frame_fav"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="30.0dip"
                        android:layout_height="30.0dip">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/share_icon"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_bilibili_share" />
                    </FrameLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/stat_zhuanfa"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_color"
                        android:textSize="11sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

    </LinearLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/msgTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/content_padding_6dp"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout4"
        tools:layout_editor_absoluteX="6dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:hint="@string/input_text"
            android:nextFocusDown="@id/search_box"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="?colorPrimary"
        android:contentDescription="@string/todo"
        android:src="@drawable/ic_refresh"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>