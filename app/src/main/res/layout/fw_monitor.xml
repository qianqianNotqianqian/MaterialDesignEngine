<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:background="@drawable/fw_monitor_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/fw_chart_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="3dp"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="35dp"
                android:layout_height="35dp">

                <mapleleaf.materialdesign.engine.view.FloatMonitorChartView
                    android:id="@+id/fw_cpu_load"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/fw_monitor_cpu"
                    android:textAlignment="center"
                    android:textColor="#ffffff"
                    android:textSize="7.3sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/fw_cpu_freq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="1dp"
                android:text="@string/fw_monitor_frequency"
                android:textAlignment="center"
                android:textColor="#ffffff"
                android:textSize="5.6sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fw_gpu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="3dp"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="35dp"
                android:layout_height="35dp">

                <mapleleaf.materialdesign.engine.view.FloatMonitorChartView
                    android:id="@+id/fw_gpu_load"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/fw_monitor_gpu"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="#ffffff"
                    android:textSize="7.3sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/fw_gpu_freq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="1dp"
                android:text="@string/fw_monitor_frequency"
                android:textColor="#ffffff"
                android:textSize="5.6sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fw_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="35dp"
                android:layout_height="35dp">

                <mapleleaf.materialdesign.engine.view.FloatMonitorBatteryView
                    android:id="@+id/fw_battery_chart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/fw_is_charger"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:alpha="0.7"
                    android:src="@drawable/ic_power_line"
                    android:tint="@color/white"
                    android:visibility="gone" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/fw_battery_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/fw_monitor_battery_level"
                    android:textAlignment="center"
                    android:textColor="#ffffff"
                    android:textSize="7.3sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/fw_battery_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="1dp"
                android:text="@string/fw_monitor_temp"
                android:textColor="#ffffff"
                android:textSize="5.6sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/fw_other_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:minWidth="70dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/fw_monitor_loading"
        android:textColor="#bbffffff"
        android:textSize="7sp"
        android:textStyle="bold"
        android:typeface="monospace"
        android:visibility="gone" />
</LinearLayout>