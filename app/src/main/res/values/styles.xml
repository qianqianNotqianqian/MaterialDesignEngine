<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="CustomMaterial3Theme" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:windowBackground">#FFFFFFFF</item>
<!--        <item name="android:colorPrimary">?colorPrimary</item>-->
<!--        <item name="android:colorPrimaryDark">?colorPrimaryDark</item>-->
<!--        <item name="android:colorAccent">?colorPrimary</item>-->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowAnimationStyle">@style/activityAnim2</item>
        <item name="toolbarStyle">@style/Material3.Toolbar</item>
    </style>

    <style name="CustomMaterial3Theme_Dark" parent="CustomMaterial3Theme" />

    <style name="CustomMaterial3ThemeSplash" parent="CustomMaterial3Theme" />

    <style name="AppTheme.PopupOverlay" parent="@style/Widget.Material3.PopupMenu">
        <item name="popupMenuBackground">@color/spinner_color2</item>
    </style>

    <!-- 定义 Toolbar 的样式 -->
    <style name="Material3.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_color</item>
        <item name="subtitleTextColor">@color/text_color</item>
    </style>

    <style name="MDEngineSeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:thumbOffset">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:splitTrack">false</item>
        <item name="android:maxHeight">20dp</item>
        <item name="android:indeterminateOnly">false</item>
        <item name="android:indeterminateDrawable">?colorPrimary</item>
        <item name="android:progressDrawable">@drawable/seekbar_progress_drawable</item>
        <item name="android:minHeight">20dp</item>
        <item name="android:thumb">@drawable/seekbar_progress_thumb</item>
        <item name="android:thumbTint">?colorPrimary</item>
        <item name="android:alpha">1</item>
        <item name="android:background">@null</item>
    </style>

    <style name="MDEngineButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:background">@drawable/button_selector</item>
        <item name="android:gravity">start|center</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="icon">@drawable/ic_forward</item>
        <item name="iconTint">@color/text_color</item>
        <item name="iconGravity">end</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CardLabel">
        <item name="android:textSize">14.0sp</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">0.0dip</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">5.0</item>
        <item name="android:textAlignment">viewStart</item>
    </style>

    <style name="CustomTextview">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginStart">3dp</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CustomMainLinearLayoutForMenu">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="CustomLinearLayoutWeightForMenu">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="CustomMaterialCardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">128dp</item>
        <item name="android:clickable">true</item>
        <item name="android:layout_marginVertical">3dp</item>
        <item name="android:layout_marginHorizontal">3dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <style name="activityAnim">
        <item name="android:activityOpenEnterAnimation">@anim/activity_open_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/activity_open_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/activity_close_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/activity_close_exit</item>
    </style>

    <style name="activityAnim2">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
<!--        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>-->
<!--        <item name="android:activityCloseEnterAnimation">@anim/slide_in_right</item>-->
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="windowAnim">
        <item name="android:windowExitAnimation">@anim/activity_open_enter</item>
        <item name="android:windowEnterAnimation">@anim/fade_out_up</item>
    </style>

    <style name="windowAnim2">
        <item name="android:windowEnterAnimation">@anim/fade_in_up</item>
        <item name="android:windowExitAnimation">@anim/fade_out_up</item>
    </style>

    <style name="custom_alert_dialog">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@null</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:backgroundDimAmount">0</item>
        <item name="android:windowAnimationStyle">@style/windowAnim2</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:padding">0dp</item>
        <item name="android:layout_margin">0dp</item>
    </style>

    <style name="textTitle" parent="@style/TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center|start</item>
        <item name="android:alpha">1</item>
    </style>

    <style name="textSmallTitle" parent="textTitle">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="textDefault">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="textSmall">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="MDEngineTabLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/transparent</item>
        <item name="tabMode">auto</item>
        <item name="tabIconTint">?colorPrimary</item>
        <item name="tabIndicator">@drawable/wallpaper_select_background</item>
        <item name="tabIndicatorAnimationDuration">500</item>
        <item name="tabIndicatorColor">?colorPrimary</item>
        <item name="tabIndicatorHeight">4dp</item>
        <item name="tabSelectedTextColor">?colorPrimary</item>
        <item name="tabRippleColor">@color/transparent</item>
        <item name="tabTextColor">@color/text_color</item>
    </style>

    <style name="MDEngineTabLayoutTop">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">?actionBarSize</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="tabMode">scrollable</item>
        <item name="tabIconTint">?colorPrimary</item>
        <item name="tabIndicator">@drawable/wallpaper_select_background</item>
        <item name="tabIndicatorAnimationDuration">500</item>
        <item name="tabIndicatorColor">?colorPrimary</item>
        <item name="tabIndicatorHeight">4dp</item>
        <item name="tabRippleColor">@color/transparent</item>
        <item name="tabSelectedTextColor">?colorPrimary</item>
        <item name="tabTextColor">@color/text_color</item>
        <item name="android:layout_gravity">end</item>
    </style>

    <style name="dialogLargeBtn" parent="@style/Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:alpha">0.8</item>
        <item name="textColor">@color/text_color</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="dialogConfirmBtn" parent="dialogLargeBtn">
        <item name="android:background">@drawable/btn_bg_large_secondary</item>
    </style>

    <style name="dialogCancelBtn" parent="dialogLargeBtn">
        <item name="android:background">@drawable/btn_bg_large_secondary</item>
    </style>

    <style name="dialogRoot">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="dialogTitle" parent="@style/textTitle">
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialogDesc" parent="@style/textSmall">
        <item name="android:layout_margin">12dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialogWarn" parent="@style/textSmall">
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/in_card_item</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialog_full_screen" parent="Theme.Material3.DayNight.NoActionBar">
        <!--<item name="android:windowNoTitle">true</item>-->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@style/windowAnim2</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:fitsSystemWindows">true</item>
        <!-- 浮于Activity之上 -->
        <item name="android:windowIsFloating">false</item>
        <!-- 边框 -->
        <item name="android:windowFrame">@null</item>
        <item name="android:windowCloseOnTouchOutside">false</item>
    </style>

    <style name="dialog_full_screen_light" parent="@style/dialog_full_screen">
        <item name="android:windowBackground">@android:color/background_light</item>
        <item name="android:statusBarColor">@android:color/background_light</item>
    </style>

    <style name="dialog_full_screen_dark" parent="@style/dialog_full_screen">
        <item name="android:windowBackground">@android:color/background_dark</item>
        <item name="android:statusBarColor">@android:color/background_dark</item>
    </style>

    <style name="CardValue">
        <item name="android:textSize">14.0sp</item>
        <item name="android:textColor">?colorPrimary</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">0.0dip</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">6.0</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:paddingStart">8.0dip</item>
    </style>

    <style name="CardItemContainer">
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ShapeAppearanceOverlay_card_custom_corners">
        <item name="cornerSizeBottomLeft">16.0dip</item>
        <item name="cornerSizeBottomRight">16.0dip</item>
        <item name="cornerSizeTopLeft">2.0dip</item>
        <item name="cornerSizeTopRight">2.0dip</item>
    </style>

    <style name="AppAboutTheme" parent="Theme.AppCompat.Light">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorPrimary</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowAnimationStyle">@style/activityAnim2</item>
    </style>

    <style name="ListCardItem">
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/linearlayout_background</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
    </style>

    <style name="ListCardItemSmall" parent="ListCardItem">
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="ListCardItemClickable" parent="ListCardItem">
        <item name="android:background">@drawable/item_app_bg</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="ListCardItemClickableLast" parent="ListCardItemClickable">
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="ListCardItemLast" parent="ListCardItem" />

    <style name="textSecondary">
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:alpha">0.5</item>
    </style>

    <style name="CustomBottomSheetDialogTheme" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:windowAnimationStyle">@style/CustomBottomSheetDialogAnimation</item>
    </style>

    <style name="CustomBottomSheetDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/fade_in_up</item>
        <item name="android:windowExitAnimation">@anim/fade_out_up</item>
    </style>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!--        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>-->
    </style>

    <!-- Base application theme. -->
    <style name="AppThemeDark" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- To customize calculator dialog's style -->
    <style name="CustomCalcDialogStyle" parent="CalcDialogStyle">
        <!--        <item name="calcNumberBtnStyle">@style/CustomNumberBtnStyle</item>-->
        <item name="calcDialogWindowAnimimation">@style/CustomWindowAnimation</item>
    </style>

    <style name="CustomWindowAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="CustomNumberBtnStyle" parent="CalcNumberBtnStyle">
        <item name="android:textSize">18sp</item>
    </style>

    <!-- DEMO APP STYLES -->
    <style name="OptionsCardViewStyle">
        <item name="android:layout_marginBottom">0dp</item>
        <item name="android:layout_marginHorizontal">6dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="SubtitleTextViewStyle">
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="android:textColor">@color/material_on_surface_emphasis_medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OptionsCheckboxStyle">
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
    </style>

    <style name="DropdownLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/mtrl_filled_background_color</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="DropdownStyle">
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="boxStrokeColor">@null</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:inputType">none|textNoSuggestions</item>
        <item name="android:imeOptions">flagNoExtractUi</item>
        <item name="android:focusable">false</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:cursorVisible">false</item>
    </style>

    <style name="InputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/mtrl_filled_background_color</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="InputStyle">
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="boxStrokeColor">@null</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:imeOptions">flagNoExtractUi|actionDone</item>
    </style>

</resources>
